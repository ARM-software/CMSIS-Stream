{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Prebuilt Executable",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Examples/events/simple.exe", // Change this path
            "args": [], // Add any command line arguments here
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "console": "externalTerminal", // or "integratedTerminal"
            "symbolSearchPath": "", // Optionally add .pdb search paths
            "logging": {
                "engineLogging": false
            }
        },
        {
            "name": "CMSIS_DAP@pyOCD (launch)",
            "type": "gdbtarget",
            "request": "launch",
            "cwd": "${workspaceFolder}/Tests",
            "program": "out/syncgraph/VHT-Corstone-300/CommandLine/syncgraph.axf",
            "gdb": "arm-none-eabi-gdb",
            "auxiliaryGdb": true,
            "preLaunchTask": "CMSIS Load",
            "initCommands": [
                "symbol-file \"out/asyncgraph/VHT-Corstone-300/CommandLine/asyncgraph.axf\"",
                "symbol-file \"out/fifobench_sync/VHT-Corstone-300/CommandLine/fifobench_sync.axf\"",
                "symbol-file \"out/fifobench_async/VHT-Corstone-300/CommandLine/fifobench_async.axf\"",
                "symbol-file \"out/fifo/VHT-Corstone-300/CommandLine/fifo.axf\"",
                "symbol-file \"out/duplicate/VHT-Corstone-300/CommandLine/duplicate.axf\"",
                "monitor reset halt",
                "tbreak main"
            ],
            "customResetCommands": [
                "monitor reset halt",
                "maintenance flush register-cache",
                "maintenance flush dcache",
                "tbreak main",
                "continue"
            ],
            "target": {
                "server": "pyocd",
                "serverParameters": [
                    "gdbserver",
                    "--probe",
                    "cmsisdap:",
                    "--connect",
                    "attach",
                    "--cbuild-run",
                    "${command:cmsis-csolution.getCbuildRunFile}",
                    "--quiet",
                    "--log",
                    "*.cbuild_run,*server=info"
                ],
                "port": "3333"
            },
            "cmsis": {
                "cbuildRunFile": "${command:cmsis-csolution.getCbuildRunFile}",
                "updateConfiguration": "auto"
            }
        },
        {
            "name": "CMSIS_DAP@pyOCD (attach)",
            "type": "gdbtarget",
            "request": "attach",
            "cwd": "${workspaceFolder}/Tests",
            "program": "out/syncgraph/VHT-Corstone-300/CommandLine/syncgraph.axf",
            "gdb": "arm-none-eabi-gdb",
            "auxiliaryGdb": true,
            "initCommands": [
                "symbol-file \"out/asyncgraph/VHT-Corstone-300/CommandLine/asyncgraph.axf\"",
                "symbol-file \"out/fifobench_sync/VHT-Corstone-300/CommandLine/fifobench_sync.axf\"",
                "symbol-file \"out/fifobench_async/VHT-Corstone-300/CommandLine/fifobench_async.axf\"",
                "symbol-file \"out/fifo/VHT-Corstone-300/CommandLine/fifo.axf\"",
                "symbol-file \"out/duplicate/VHT-Corstone-300/CommandLine/duplicate.axf\"",
                ""
            ],
            "customResetCommands": [
                "monitor reset halt",
                "maintenance flush register-cache",
                "maintenance flush dcache",
                "tbreak main",
                "continue"
            ],
            "target": {
                "port": "3333"
            },
            "cmsis": {
                "cbuildRunFile": "${command:cmsis-csolution.getCbuildRunFile}",
                "updateConfiguration": "auto"
            }
        }
    ]
}
