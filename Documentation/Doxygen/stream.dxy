SHOW_USED_FILES        = YES
SHOW_FILES             = YES
SHOW_NAMESPACES        = YES
FILE_VERSION_FILTER    =
LAYOUT_FILE            = ./style_template/layout.xml

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_IF_UNDOC_ENUM_VAL = NO
WARN_AS_ERROR          = NO
WARN_FORMAT            = "$file:$line: $text"
WARN_LOGFILE           =

INPUT                  = ./src/mainpage.md \
                         ./src/01_files_copied.md \
                         ./src/02_start.md \
                         ./src/03_configuration.md \
                         ./src/files.dox \
                         ../../platform/cg_enums.h \
                         ../../platform/cg_pack.hpp \
                         ../../platform/EventDisplay.hpp \
                         ../../platform/EventQueue.hpp \
                         ../../platform/GenericNodes.hpp \
                         ../../platform/StreamNode.hpp \
                         ../../platform/cmsis_rtos_runtime
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.h \
                         *.hpp \
                         *.cpp \
                         *.dox \
                         *.md
RECURSIVE              = YES
EXCLUDE                =
EXCLUDE_SYMLINKS       = YES
EXCLUDE_PATTERNS       = */platform/cmsis_rtos_runtime/README.md
EXCLUDE_SYMBOLS        =
EXAMPLE_PATH           =
EXAMPLE_PATTERNS       = *
EXAMPLE_RECURSIVE      = NO
IMAGE_PATH             =
INPUT_FILTER           =
FILTER_PATTERNS        =
FILTER_SOURCE_FILES    = NO
FILTER_SOURCE_PATTERNS =
