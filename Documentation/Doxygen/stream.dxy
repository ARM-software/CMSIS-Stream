# Doxyfile for CMSIS-Stream platform and CMSIS-RTOS runtime documentation.

DOXYFILE_ENCODING      = UTF-8
PROJECT_NAME           = "CMSIS-Stream"
PROJECT_NUMBER         = "Version v3.2.0-18-ga34eca3-dirty"
PROJECT_BRIEF          = "CMSIS-Stream Platform and CMSIS-RTOS Runtime API"
PROJECT_LOGO           = ./style_template/cmsis_logo_white_small.png
OUTPUT_DIRECTORY       = ./
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English
BRIEF_MEMBER_DESC      = YES
